@page "/cardapio"
@using GoodHamburger.Web.Models.Reponse
@inject GoodHamburger.Web.Services.PedidoApiService Api

<h2 class="fw-bold mb-4">📋 Cardápio</h2>

@if (_carregando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-warning"></div>
    </div>
} else{
    <div class="row g-3">
        @foreach (var categoria in _itens.GroupBy(i => i.CategoriaItem))
        {
            <h5 class="mt-3 fw-bold text-uppercase text-muted">
                @categoria.Key
            </h5>
            @foreach(var item in categoria)
            {
                <div class="col-12 col-sm-6 col-md-4">
                    <div class="card h-100 shadow border-0">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <h6 class="card-title fw-bold mb-1">
                                @item.Nome
                            </h6>
                            <span class="badge bg-secondary">
                                @item.TipoItem
                            </span>
                        </div>
                        <span class="fs-5 fw-bold text-warning">R$ @item.Preco.ToString("F2")</span>
                    </div>
                </div>
            }
        }
    </div>
    <div class="card mt-4 border-4">
        <div class="card-header bg-warning fw-bold">
            🏷️ Descontos
        </div>
        <ul class="list-group list-group-flush">
            <li class="list-group-item">
                🍔 + 🍟 + 🥤 → <strong>20% de desconto</strong>
            </li>
            <li class="list-group-item">
                🍔 + 🥤 → <strong>15% de desconto</strong>
            </li>
            <li class="list-group-item">
                🍔 + 🍟 → <strong>10% de desconto</strong>
            </li>
        </ul>
    </div>
}
@code{
    private List<ItemCardapioResponse> _itens = new();
    private bool _carregando = true;
    protected override async Task OnInitializedAsync()
    {
        _itens = await Api.ObterCardapioAsync();
        _carregando = false;
    }
}